  GUI.Tabs.AutoFarm.Sections.OtherAutoFarm.Callbacks.ToggleLureboxFarm = function(v)
    WriteConsoleLog("Lurebox auto farm triggered", nil, "DEBUG")
    WriteFileLog("Lurebox auto farm triggered", "DEBUG")
    if v then
      WriteConsoleLog("Lurebox auto farm enabled", nil, "DEBUG")
      WriteFileLog("Lurebox auto farm enabled", "DEBUG")
      Cooldown.AutoFarm.LureboxFarm = 0
      Registry.RegisterTask("lurebox_farm_handler", function()
        Cooldown.AutoFarm.LureboxFarm = nil
        WriteConsoleLog("[Registry]: {lurebox_farm_handler} runned", nil, "DEBUG")
        WriteFileLog("[Registry]: {lurebox_farm_handler} runned", "DEBUG")
        if count(ClientData.get("lures_2023_lure_manager").lures_map) == 0 then 
          SafeInvoke("HousingAPI/ActivateFurniture",
            LocalPlayer,
            furn.lurebox.unique,
            "UseBlock",
            {
              bait_unique = InvGetCategoryUnique("food", "ice_dimension_2025_ice_soup_bait") 
            },
            LocalPlayer.Character
          )
          task.wait(2)
          local l = ClientData.get("lures_2023_lure_manager").lures_map.BasicLure
          if l and l.bait_kind then
            WriteConsoleLog(string.format("Lurebox bait placed:", l.bait_kind), string.format("[📦]:[✅] Bait placed:", l.bait_kind), "DEBUG")
            WriteFileLog(string.format("Lurebox bait placed:", l.bait_kind), "DEBUG")
          else
            WriteConsoleLog(string.format("Lurebox bait not placed. Repeating after {5}s", l.bait_kind), string.format("[📦]:[❌] Bait not placed. Repeating after [5]s."), "ERROR")
            WriteFileLog(string.format("Lurebox bait not placed. Repeating after {5}s", l.bait_kind), "ERROR")
            Cooldown.AutoFarm.LureboxFarm = 5
            return
          end
          local tmps = ClientData.get("lures_2023_lure_manager").lure_start_timestamp 
          local ok, tms = pcall(LiveOpsTime.get_time_until, tmps)
          if not ok or not tms then 
            tms = 3600 
          end
          Cooldown.AutoFarm.LureboxFarm = tms + 5
        else
          local l = ClientData.get("lures_2023_lure_manager").lures_map.BasicLure or {}
          if not l.finished then
            local tmps = ClientData.get("lures_2023_lure_manager").lure_start_timestamp 
            local ok, tms = pcall(LiveOpsTime.get_time_until, tmps)
            if not ok or not tms then 
              tms = 3600 
            end
            Cooldown.AutoFarm.LureboxFarm = tms + 5    
          else
            local reward = l.reward or {kind="Unidentified reward", amount=1}
            SafeInvoke("HousingAPI/ActivateFurniture",
              LocalPlayer,
              furn.lurebox.unique,
              "UseBlock",
              false,
              LocalPlayer.Character
            )
            task.wait(1)
            local luresmap = ClientData.get("lures_2023_lure_manager").lures_map 
            if count(luresmap) == 0 then
              WriteConsoleLog(string.format("{%d %s} Found in lurebox", reward.amount, reward.kind), string.format("[📦]:[🎁] [%d %s] Found in lurebox.", reward.amount, reward.kind), "DEBUG")
              WriteFileLog(string.format("{%d %s} Found in lurebox", reward.amount, reward.kind), "DEBUG")
              Cooldown.AutoFarm.LureboxFarm = 1
            else
              WriteConsoleLog("Unsuccessed to get lurebox reward. Repeating after {5}s", "[📦]:[❌] Unsuccessed to get lurebox reward. Repeating after [5]s.", "ERROR")
              WriteFileLog("Unsuccessed to get lurebox reward. Repeating after [5]s", "ERROR")
              Cooldown.AutoFarm.LureboxFarm = 5
            end
          end 
        end
      end,
      function()
        return Cooldown.AutoFarm.LureboxFarm == 0
      end,
      function()
        Cooldown.AutoFarm.LureboxFarm = 10
      end)
    else
      WriteConsoleLog("Lurebox auto farm disabled", nil, "DEBUG")
      WriteFileLog("Lurebox auto farm disabled", "DEBUG")
      Registry.UnregisterTask("lurebox_farm_handler")
      Cooldown.AutoFarm.LureboxFarm = nil
    end
  end
  
