  GUI.Tabs.AutoFarm.Sections.OtherAutoFarm.Callbacks.TogglePetRecycler = function(v) 
    WriteConsoleLog("Auto recycle pets triggered", nil, "DEBUG")
    WriteFileLog("Auto recycle pets triggered", "DEBUG")
    if v then
      WriteConsoleLog("Auto recycle pets enabled", nil, "DEBUG")
      WriteFileLog("Auto recycle pets enabled", "DEBUG")
      Cooldown.AutoFarm.PetRecycler = 0
      Registry.RegisterTask("pet_recycler_handler", function()
        Cooldown.AutoFarm.PetRecycler = nil
          local pets_to_exchange = {}
          local owned_pets = GetOwnedPets()
          local value = 0
          for k,v in owned_pets do
            if v.remote == "practice_dog" then continue end
            if (v.name:lower()):match("egg") then continue end
            if _G.InternalConfig.RecyclerDLib.BlacklistedRarities and _G.InternalConfig.RecyclerDLib.BlacklistedRarities[v.rarity] then continue end
            if _G.InternalConfig.RecyclerDLib.BlacklistedAges and _G.InternalConfig.RecyclerDLib.BlacklistedAges[v.age] then continue end
            if _G.InternalConfig.RecyclerDLib.BlacklistedProperties and _G.InternalConfig.RecyclerDLib.BlacklistedProperties[v.age] then continue end
            if _G.InternalConfig.RecyclerDLib.BlacklistedSpecificPets and _G.InternalConfig.RecyclerDLib.BlacklistedSpecificPets[k] then continue end
            local ok, val = pcall(Calculator.get_pet_value, 
              { 
                kind = v.remote, 
                properties = {
                  age = v.age,
                  neon = v.neon,
                  mega_neon = v.mega_neon,
                  rideable = v.rideable,
                  flyable = v.flyable
                },
              }
            ) 
            if ok then 
              value += val 
              pets_to_exchange[k] = true
            end
          end
        local val = (value + (ClientData.get("pet_recycler_manager").saved_points or 0)) 
          if val >= 4500 then 
            local _task = LocationQueue.Enqueue(function()
              emulate_location("Nursery")
            end)
            while not _task.started do
              task.wait(.2)
            end
            if not ClientData.get("pet_recycler_manager").timestamp then
              safeInvoke("HousingAPI/ActivateInteriorFurniture",
                "f-9",
                "UseBlock",
                {
                  action = "use",
                  uniques = pets_to_exchange
                },
                LocalPlayer.Character
              )
              LocationQueue.Complete(_task)
              task.wait(1)
              local tmps = ClientData.get("pet_recycler_manager").timestamp
              local ok, tms = pcall(LiveOpsTime.get_time_until, tmps)
              if not ok or not tms then 
                tms = 300
              end
              Cooldown.AutoFarm.PetRecycler = tms + 5
              return
            end
        else 
          WriteConsoleLog(string.format("Not enough points to use pet recycler (%d of 4500). Next try in [300]s", val), string.format("[♻️]:[❌] Not enough points to use pet recycler (%d of 4500). Next try in [300]s.", val), "DEBUG")
          WriteFileLog(string.format("Not enough points to use pet recycler (%d of 4500). Next try in [300]s", val), "DEBUG")
          Cooldown.AutoFarm.PetRecycler = 300 
          return
        end
      end,
      function()
        return Cooldown.AutoFarm.PetRecycler == 0
      end,
      function()
        Cooldown.AutoFarm.PetRecycler = 5
      end)
    else
      WriteConsoleLog("Auto recycle pets disabled", nil, "DEBUG")
      WriteFileLog("Auto recycle pets disabled", "DEBUG")
      Registry.UnregisterTask("pet_recycler_handler")
      Cooldown.AutoFarm.PetRecycler = nil
    end
  end

