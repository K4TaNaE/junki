    local _condition = condition
    local _fallback = fallback
    Registry.Tasks[_flag] = {['_flag'] = _flag, ["_callback"] = _callback, ["_condition"] = _condition, ["_fallback"] = _fallback, _active = true}
    WriteConsoleLog(string.format("[Registry]: Task registered. _flag: {%s} : {%s}", _flag, (debug.info(_callback, "n") or tostring(_callback))), nil, "DEBUG")
    WriteFileLog(string.format("[Registry]: Task registered. _flag: {%s} : {%s}", _flag, (debug.info(_callback, "n") or tostring(_callback))), "DEBUG")
  end

  function Registry.RunTask(flag :string, callback :Callback)
    local _flag = flag
    if Registry.Tasks[_flag] then
      return
    end
    Registry.DisposableTasks[_flag] = {["_flag"] = _flag, ["_callback"] = callback}
    task.spawn(function() 
      local ok, _ = pcall(callback)
      if not ok then
        WriteConsoleLog(string.format("[Registry]: Disposable task crashed. _flag: {%s} : {%s}", _flag, (debug.info(callback, "n") or tostring(callback))), nil, "DEBUG")
        WriteFileLog(string.format("[Registry]: Disposable task crashed. _flag: {%s} : {%s}", _flag, (debug.info(callback, "n") or tostring(callback))), "DEBUG")
      end
      Registry.DisposableTasks[_flag] = nil
    end)
    WriteConsoleLog(string.format("[Registry]: Disposbale task registered. _flag: {%s}", _flag), nil, "DEBUG")
    WriteFileLog(string.format("[Registry]: Disposable task registered. _flag: {%s}", _flag), "DEBUG")
  end

  function Registry.Exists(flag :string) 
    return Registry.Tasks[flag] or Registry.DisposableTasks[flag]
  end

  function Registry.__InitTaskHandler()
    while task.wait(.1) do
      for _,v in Registry.Tasks do
        if v._condition() then
          WriteConsoleLog(string.format("[Registry]: Task condition reached. _flag: {%s} : {%s}", v._flag, (debug.info(v._callback, "n") or tostring(v._callback))), nil, "DEBUG")
          WriteFileLog(string.format("[Registry]: Task condition reached. _flag: {%s} : {%s}", v._flag, (debug.info(v._callback, "n") or tostring(v._callback))), "DEBUG")
          task.spawn(function() 
            local ok, _ = pcall(v._callback)
            if not ok then
              WriteConsoleLog(string.format("[Registry]: Task crashed. _flag: {%s} : {%s}", v._flag, (debug.info(v._callback, "n") or tostring(v._callback))), nil, "DEBUG")
              WriteFileLog(string.format("[Registry]: Task crashed. _flag: {%s} : {%s}", v._flag, (debug.info(v._callback, "n") or tostring(v._callback))), "DEBUG")
              pcall(v._fallback)
            end
          end)
        end
      end
    end
  end

  function Registry.UnregisterTask(flag :string)
    local _task = Registry.Tasks[flag]
    if _task then
      Registry.Tasks[flag] = nil
      WriteConsoleLog(string.format("[Registry]: Task unregistered. _flag: {%s}", flag), nil, "DEBUG")
      WriteFileLog(string.format("[Registry]: Task unregistered. _flag: {%s}", flag), "DEBUG")
    end
  end

  -- marks all tasks as inactive
  function Registry.EmergencyStop()
    for _,v in Registry.Tasks do
      v._active = false
    end
  end

  function Registry.MarkTaskAsActive(flag :string)
    local _task = Registry.Tasks[flag]
    if _task then
      _task._active = true
    else
    end  
  end

  -- marks all tasks as active
  function Registry.EmergencyResume()
    for _,v in Registry.Tasks do
      v._active = true
    end
  end

  -- inactive tasks are not runninng
  function Registry.MarkTaskAsInactive(flag :string)
    local _task = Registry.Tasks[flag]
    if _task then
      _task._active = false
    else
    end
  end

  function LocationQueue.CreateTask(callback :Callback)
    return {
      callback = callback,
      completed = false,
      started = false,
      resume = nil,
    }
  end

  function LocationQueue._process()
    if LocationQueue._running then return end
    LocationQueue._running = true
    while #LocationQueue._queue > 0 do
      local _task = table.remove(LocationQueue._queue, 1)
      _task.started = true
      _task.callback()
      local startTime = os.clock()
      while not _task.completed do
        if os.clock() - startTime >= 65 then
          WriteConsoleLog(string.format("[Location Change Queue]: Task reached the deadline. Crashing. function: {%s}",(debug.info(_task.callback, "n") or tostring(_task.callback))), nil, "ERROR")
          WriteFileLog(string.format("[Location Change Queue]: Task reached the deadline. Crashing. function: {%s}",(debug.info(_task.callback, "n") or tostring(_task.callback))), "ERROR")
          _task.completed = true
          break
        end
        _task.resume = coroutine.running()
        coroutine.yield()
      end
    end
    LocationQueue._running = false
  end

  function LocationQueue.Enqueue(callback :Callback)
    local _task = LocationQueue.CreateTask(callback)
    table.insert(LocationQueue._queue, _task)
    _task.resume = nil
    coroutine.wrap(LocationQueue._process)()
    WriteConsoleLog(string.format("[Location Change Queue]: Task entered queue. function: {%s}", (debug.info(callback, "n") or tostring(callback))), nil, "DEBUG")
    WriteFileLog(string.format("[Location Change Queue]: Task entered queue. function: {%s}", (debug.info(callback, "n") or tostring(callback))), "DEBUG")
    return _task
  end

  function LocationQueue.Complete(task)
      task.completed = true      
      WriteConsoleLog(string.format("[Location Change Queue]: Task marked as completed. function: {%s}", (debug.info(task.callback, "n") or tostring(task.callback))), nil, "DEBUG")
      WriteFileLog(string.format("[Location Change Queue]: Task marked as completed. function: {%s}", (debug.info(task.callback, "n") or tostring(task.callback))), "DEBUG")
      if task.resume then
        coroutine.resume(task.resume)
      end
  end

