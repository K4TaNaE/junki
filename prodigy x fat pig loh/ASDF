		  local desc = "Unknown Error."
		  if data and data.description then
			  desc = data.description
		  end
      WriteConsoleLog("Invalid bot API key: " .. desc, "[-] Invalid bot API key: " .. desc .. ".", "ERROR")
      WriteFileLog("Invalid bot API key: " .. desc, "ERROR")
      GUI.Notify("Error", "Invalid bot API key: " .. desc .. string.format(". Setting value to {%s}", (_G.InternalConfig.TelegramBotApi or "")), "ERROR", "circle-x")
      GUI.TextFieldSetValue(TelegramBotApiKeyTextField, _G.InternalConfig.TelegramBotApi or "") 
	  else
      _G.InternalConfig.TelegramBotApi = table.unpack(v)
      WriteConsoleLog(string.format("Telegram bot API key is valid: {%s}", table.unpack(v)), "[+] Telegram bot API key is valid.", "DEBUG")
      WriteFileLog(string.format("Telegram bot API key is valid: {%s}", table.unpack(v)), "DEBUG")
      GUI.Notify("Info", "Telegram bot API key is valid", "INFO", "circle-x")
    end
  end

  GUI.Tabs.Webhooks.Sections.Telegram.Callbacks.HandleTelegramChatId = function(v) 
    WriteConsoleLog("Telegram chat id triggered", nil, "DEBUG")
    WriteFileLog("Telegram chat id triggered", "DEBUG")
    if v:match("^%s*$") then
      _G.InternalConfig.TelegramChatId = false
      GUI.ToggleButtonSetValue(TelegramWebhooksToggleButton, false)
      return
    end
    WriteConsoleLog("Trying to send message through telegram bot to check chat id", "Trying to send message through telegram bot to check chat id..", "DEBUG")
    WriteFileLog(string.format("Trying to send message through telegram bot to check chat id", "DEBUG"))
		local ok, res = pcall(function()
  	  return request({
    	  Url = "https://api.telegram.org/bot" .. _G.InternalConfig.TelegramBotApi .. "/sendMessage",
			  Method = "POST",
			  Headers = { ["Content-Type"] = "application/json" },
			  Body = HttpService:JSONEncode({
				  chat_id = v,
				  text = "test"
			  })
		  })
		end)
