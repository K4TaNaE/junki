local function IntegrityCheck(func_set :table, on_fallback :Callback, replace :Callback, on_success)
  for _,v in ipairs(func_set) do
    if v then 
      pcall(on_success)
      return v 
    end
  end
  pcall(on_fallback)
  return replace
end
