  local function __init_automated_pet_farm()   
    Cooldown.AutoFarm.PetAutoFarm = nil
    if count(ClientData.get("inventory").pets) < 1 then
      Cooldown.AutoFarm.PetAutoFarm = 50 
      return
    end
    local flag = false
    local kitty_unique
    if _G.InternalConfig.PetFarmDLib.Detect2DKitty then
      if kitty_unique == actual_pet.unique and kitty_unique == ClientData.get("pet_char_wrappers")[1].pet_unique then
        flag = true
      else
        kitty_unique = InvGetCategoryUnique("pets", "2d_kitty")
        if kitty_unique and kitty_unique ~= actual_pet.unique then
          SafeInvoke("ToolAPI/Equip",
            kitty_unique,
            {
              use_sound_delay = true,
              equip_as_last = false
            }
          )
          print("🐱 Found and equiped 2D-kitty.")
          WriteConsoleLog("2D-kitty detected and equiped", "🐱 2D-kitty detected and equiped.", "DEBUG")
          WriteFileLog("2D-kitty detected and equiped", "DEBUG")
          flag = true
          _G.InternalConfig.PetFarmDLib.flag_if_no_one_to_farm = false
          _G.InternalConfig.PetFarmDLib.KittyInUse = true
          task.wait(1)
          PetUpdate() 
          task.wait(.2)
        end
      end
    else
      _G.InternalConfig.PetFarmDLib.KittyInUse = false
    end
    if not _G.InternalConfig.PetFarmDLib.KittyInUse then
      if (actual_pet.unique and not Equiped()) or (actual_pet.unique and actual_pet.unique ~= CurUnique()) then
        SafeInvoke("ToolAPI/Equip",
          actual_pet.unique, 
          {
            use_sound_delay = true,
            equip_as_last = false
          }
        )	 
        print(string.format("🐶 Pet has been changed. Switching back to: %s", actual_pet.remote or "pet not detected."))
        flag = true
        task.wait(.5)
      end
    end
    if not Equiped() or CurUnique() ~= actual_pet.unique then
      actual_pet.unique = false
      if _G.InternalConfig.PetFarmDLib.flag_if_no_one_to_farm then
        print("⚙️ Opposite farm disabled.")
      end
      _G.InternalConfig.PetFarmDLib.flag_if_no_one_to_farm = false
      _G.InternalConfig.PetFarmDLib.random_farm = false
      _G.InternalConfig.PetFarmDLib.potionfarm = false
    end 
    if not actual_pet.unique then
      local owned_pets = GetOwnedPets()
      if table.unpack(PetAutoFarmFarmPriorityDropdown.CurrentOption) == "pets" then	
        local found = false
        for _,r in ipairs(Rarities) do
          for k,v in pairs(owned_pets) do
            if v.remote ~= "practice_dog" and v.rarity == r and v.age < 6 and not _G.InternalConfig.PetFarmDLib.PetsToExclude[v.remote] and not (v.name:lower()):match("egg") then
              SafeInvoke("ToolAPI/Equip",
                k,
                {
                  use_sound_delay = true,
                  equip_as_last = false
                }
              )
              flag = true
              found = true
              _G.InternalConfig.PetFarmDLib.flag_if_no_one_to_farm = false
              _G.InternalConfig.PetFarmDLib.random_farm = false
              break
            end
          end
          if found then break end
        end
      else 
        for k,v in pairs(owned_pets) do
          if not _G.InternalConfig.AutoFarmFilter.PetsToExclude[v.remote] and (v.name:lower()):match("egg") then
            SafeInvoke("ToolAPI/Equip",
              k,
              {
                use_sound_delay = true,
                equip_as_last = false
              }
            )
            flag = true
            _G.InternalConfig.PetFarmDLib.flag_if_no_one_to_farm = false
            _G.InternalConfig.PetFarmDLib.random_farm = false
            break
          end
        end
      end  	
      if not flag then
        if _G.InternalConfig.PetFarmDLib.OppositeFarm then
          if not _G.InternalConfig.PetFarmDLib.flag_if_no_one_to_farm then  
            print("⚙️ Enabling opposite farm..")
            if table.unpack(PetAutoFarmFarmPriorityDropdown.CurrentOption) == "pets" then
              local found = false
              for _,r in ipairs(Rarities) do
                for k,v in pairs(owned_pets) do
                  if v.remote ~= "practice_dog" and v.rarity == r and not _G.InternalConfig.PetFarmDLib.PetsToExclude[k] and not (v.name:lower()):match("egg") then
                    SafeInvoke("ToolAPI/Equip",
                      k,
                      {
                        use_sound_delay = true,
                        equip_as_last = false
                      }
                    )
                    flag = true
                    found = true
                    _G.InternalConfig.PetFarmDLib.random_farm = true
                    _G.InternalConfig.PetFarmDLib.flag_if_no_one_to_farm = true
                    if _G.InternalConfig.PetFarmDLib.PotionFarm then
                      _G.InternalConfig.PetFarmDLib.potionfarm = true
                    end
                    break
                  end 
                end
                if found then break end
              end
              if not found then
                local found = false
                for _,r in ipairs(Rarities) do
                  for k,v in pairs(owned_pets) do
                    if v.remote ~= "practice_dog" and v.rarity == r and not _G.InternalConfig.PetFarmDLib.PetsToExclude[k] then
                      SafeInvoke("ToolAPI/Equip",
                        k,
                        {
                          use_sound_delay = true,
                          equip_as_last = false
                        }
                      )
                      flag = true
                      found = true
                      _G.InternalConfig.PetFarmDLib.flag_if_no_one_to_farm = true
                      _G.InternalConfig.PetFarmDLib.random_farm = true
                      break
                    end
                  end
                  if found then break end
                end
              end
            else
              local found = false
              for _,r in ipairs(Rarities) do
                for k,v in pairs(owned_pets) do
                  if v.remote ~= "practice_dog" and v.rarity == r and not _G.InternalConfig.PetFarmDLib.PetsToExclude[k]  then
                    SafeInvoke("ToolAPI/Equip",
                      k,
                      {
                        use_sound_delay = true,
                        equip_as_last = false
                      }
                    )
                    flag = true
                    found = true
                    _G.InternalConfig.PetFarmDLib.flag_if_no_one_to_farm = true
                    _G.InternalConfig.PetFarmDLib.random_farm = true
                    break
                  end
                end
                if found then break end
              end
            end
            if not flag then
              local practice_dog = InvGetCategoryUnique("pets", "practice_dog")
              if practice_dog then 
                SafeInvoke("ToolAPI/Equip",
                  practice_dog,
                  {
                    use_sound_delay = true,
                    equip_as_last = false
                  }
                )
                flag = true
                _G.InternalConfig.PetFarmDLib.flag_if_no_one_to_farm = true
                _G.InternalConfig.PetFarmDLib.random_farm = true
                task.wait(2)
                if CurUnique() ~= practice_dog then
                  flag = false
                  _G.InternalConfig.PetFarmDLib.random_farm = false
                  _G.InternalConfig.PetFarmDLib.flag_if_no_one_to_farm = false
                end
              end
            end
          end
        end
      end  

      if (flag and not Equiped()) then
        Cooldown.AutoFarm.PetAutoFarm = 5
        return
      end
      -- if not _G.InternalConfig.PetFarmDLib.flag_if_no_one_to_farm and _G.InternalConfig.PetFarmDLib.random_farm then
      --     print("⚙️ Opposite farm disabled.")
      --     _G.InternalConfig.PetFarmDLib.random_farm = false
      -- end
      if flag then 
        task.wait(1)
        PetUpdate()
        task.wait(.2)
        if actual_pet.unique then
          print("🐨 New pet to farm detected:", actual_pet.remote)
        end
      end
    end
    local eqailments = GetEquipedPetAilments()
    print(string.format("🔎 Detecting tasks for %s..", actual_pet.remote))
    for k,_ in pairs(eqailments) do 
      if pet_ailments[k] then
        HouseCheck()
        if k == "mystery" then 
          if not _G.mystery then
            print(formatted_pet["mystery"], actual_pet.remote)
            task.spawn(pet_ailments[k]) 
          end
          continue
        end
        print(formatted_pet[k], actual_pet.remote)
        pcall(pet_ailments[k])
        if CONNECTIONS.WalkLock then CONNECTIONS.WalkLock:Disconnect(); CONNECTIONS.WalkLock = nil end
        if CONNECTIONS.RideLock then CONNECTIONS.RideLock:Disconnect(); CONNECTIONS.RideLock = nil end
        Cooldown.AutoFarm.PetAutoFarm = 0
        return
      end
    end
    Cooldown.AutoFarm.PetAutoFarm = 15

  end

