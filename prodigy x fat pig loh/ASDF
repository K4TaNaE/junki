      WriteFileLog("Gift auto buy enabled", "DEBUG")
      Cooldown.AutoFarm.TryBuyGiftAfter = 0
      Registry.RegisterTask("gift_auto_buy_handler", function()
        Cooldown.AutoFarm.TryBuyGiftAfter = nil
        WriteConsoleLog("[Registry]: {gift_auto_buy_handler} runned", nil, "DEBUG")
        WriteFileLog("[Registry]: {gift_auto_buy_handler} runned", "DEBUG")
        local money = ClientData.get("money")
        local gift = table.unpack(GiftToBuyDropdown.CurrentOption) 
        local can_afford = math.floor(money / EggRemotes[egg]) 
        local bc = math.min(can_afford, _G.InternalConfig.GiftsToBuyLeft, 99) 
        GUI.Notify("Info", "Buying gifts..", "INFO", "info")
        SafeInvoke("ShopAPI/BuyItem",
          "gifts",
          gift,
          {
            buy_count = bc
          }
        )
        WriteConsoleLog(string.format("%d gifts bought!", bc), string.format("[🎁]:[✅] %d gifts bought!", bc), "DEBUG")
        WriteFileLog(string.format("%d gifts bought!", bc), "DEBUG")
        GUI.Notify("Info", string.format("%d gifts bought!", bc), "INFO", "info")
        _G.InternalConfig.GiftsToBuyLeft -= bc
        farmed.total_gifts_bought += bc
        GUI.LabelUpdate(GiftsBoughtLabel, string.format("%d : Gifts bought", farmed.total_gifts_bought), "gift", Color3.fromRGB(203, 92, 255), false)
        if _G.InternalConfig.GiftsToBuyLeft == 0 then
