    if not v then
      WriteConsoleLog("Gift auto buy disabled", nil, "DEBUG")
      WriteFileLog("Gift auto buy disabled", "DEBUG")
      Registry.UnregisterTask("gift_auto_buy_handler")
      Cooldown.AutoFarm.TryBuyGiftAfter = nil
    else
