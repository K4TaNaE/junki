  local function NeonAndMegaNeonInstantListUpdate()
    local __neon_temp = {}
    local __meganeon_temp = {}
    local neon = {}
    local meganeon = {}
    for k,v in pairs(GetOwnedPets()) do
      if v.age == 6 then
        __neon_temp[v.id] = (__neon_temp[v.id] or 0) + 1
      end
      if v.neon and v.age == 6 then
        __meganeon_temp[v.id] = (__meganeon_temp[v.id] or 0) + 1
      end
    end
    for k,v in pairs(__neon_temp) do
      if v >= 4 then
        neon[k] = GetNameFromRemote(k)
      end
    end
    for k,v in pairs(__meganeon_temp) do
      if v >= 4 then
        meganeon[k] = GetNameFromRemote(k)
      end
    end
    GUI.DropdownUpdateOptionList(PetToMegaNeonDropdown, meganeon)
    GUI.DropdownUpdateOptionList(PetToNeonDropdown, neon)
  end

