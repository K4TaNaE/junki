  GUI.Tabs.AutoFarm.Sections.OtherAutoFarm.Callbacks.ToggleGiftAutoOpen = function(v) 
    WriteConsoleLog("Gift auto open triggered", nil, "DEBUG")
    WriteFileLog("Gift auto open triggered", "DEBUG")
    if v then
      WriteConsoleLog("Gift auto open enabled", nil, "DEBUG")
      WriteFileLog("Gift auto open enabled", "DEBUG")
      Cooldown.AutoFarm.AutoOpenGiftsAfter = 0
      Registry.RegisterTask("auto_open_gifts_handler", function()
        Cooldown.AutoFarm.AutoOpenGiftsAfter = nil
        WriteConsoleLog("[Registry]: {auto_open_gifts_handler} runned", nil, "DEBUG")
        WriteFileLog("[Registry]: {auto_open_gifts_handler} runned", "DEBUG")
        if count(GetOwnedCategory("gifts")) < 1 then
          WriteConsoleLog("[Gift AutoOpen]: No gifts detected", "📦 No gifts detected.", "DEBUG")
          WriteFileLog("[Gift AutoOpen]: No gifts detected", "DEBUG")
          Cooldown.AutoFarm.AutoOpenGiftsAfter = 120
          return
        end
        local _opened = 0
        local to_open = GiftsHelper[table.unpack(SpecificGiftToOpenDropdown.CurrentOption)]
        if to_open == "chests" then
          for k,v in pairs(GetOwnedCategory("gifts")) do
            local r = v.remote:lower()
            if r:match("chest") then
              safeInvoke("LootBoxAPI/ExchangeItemForReward", v.remote, k)
              _opened += 1
            end
          end
        elseif to_open == "all" then
          for k,v in pairs(GetOwnedCategory("gifts")) do
            local r = v.remote:lower()
              if r:match("box") or r:match("chest") then
                safeInvoke("LootBoxAPI/ExchangeItemForReward", v.remote, k)
                _opened += 1
              else
                safeInvoke("ShopAPI/OpenGift", k)
                _opened += 1
              end
          end
        else
          for k,v in pairs(GetOwnedCategory("gifts")) do
            if v.id == to_open then
              safeInvoke("ShopAPI/OpenGift", k)
              _opened += 1
            end
          end
        end
        local _type = ("gifts/chests" and to_open == "all") or ("chests" and to_open == "chests") or "gifts"
        GUI.Notify("Info", string.format("Opened %d %s", _opened, _type), "INFO", "circle-check")
        WriteConsoleLog(string.format("Opened %d %s", _opened, _type), string.format("[📦]:[✅] Opened %d %s!", _opened, _type), "DEBUG")
        WriteFileLog(string.format("Opened %d %s", _opened, _type), "DEBUG")
        Cooldown.AutoFarm.AutoOpenGiftsAfter = 120 
      end,
      function()
        return Cooldown.AutoFarm.AutoOpenGiftsAfter == 0
      end,
      function()
        Cooldown.AutoFarm.AutoOpenGiftsAfter = 1
      end)
    else
      WriteConsoleLog("Gift auto open disabled", nil, "DEBUG")
      WriteFileLog("Gift auto open disabled", "DEBUG")
      Registry.UnregisterTask("auto_open_gifts_handler")
    end
  end

