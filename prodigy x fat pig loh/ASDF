  GUI.Tabs.AutoFarm.Sections.OtherAutoFarm.Callbacks.EggAutoBuyLoopHandler = function(v)
    WriteConsoleLog("Egg auto buy triggered", nil, "DEBUG")
    WriteFileLog("Egg auto buy triggered", "DEBUG")
    if not v then
      WriteConsoleLog("Egg auto buy disabled", nil, "DEBUG")
      WriteFileLog("Egg auto buy disabled", "DEBUG")
      Registry.UnregisterTask("egg_auto_buy_handler")
      Cooldown.AutoFarm.TryBuyEggAfter = nil
    else
      if table.unpack(EggToBuyDropdown.CurrentOption) == "" then
        GUI.Notify("Warning", "Set <Egg To Buy> at first.", "WARNING", "triangle-alert")
        GUI.ToggleButtonSetValue(EggAutoBuyToggleButton, false)
        return
      end
      if EggBuyCountTextField.CurrentValue == "" then
        GUI.Notify("Warning", "Set <Buy count> at first.", "WARNING", "triangle-alert")
        GUI.ToggleButtonSetValue(EggAutoBuyToggleButton, false)
        return
      end
      WriteConsoleLog("Egg auto buy enabled", nil, "DEBUG")
      WriteFileLog("Egg auto buy enabled", "DEBUG")
      Cooldown.AutoFarm.TryBuyEggAfter = 0
      Registry.RegisterTask("egg_auto_buy_handler", function()
        Cooldown.AutoFarm.TryBuyEggAfter = nil
        WriteConsoleLog("[Registry]: {egg_auto_buy_handler} runned", nil, "DEBUG")
        WriteFileLog("[Registry]: {egg_auto_buy_handler} runned", "DEBUG")
        local money = ClientData.get("money")
        local egg = table.unpack(EggToBuyDropdown.CurrentOption) 
        local can_afford = math.floor(money / EggRemotes[egg]) 
        local bc = math.min(can_afford, _G.InternalConfig.EggsToBuyLeft, 99) 
        GUI.Notify("Info", "Buying eggs..", "INFO", "info")
        SafeInvoke("ShopAPI/BuyItem",
          "pets",
          egg,
          {
            buy_count = bc
          }
        )
        WriteConsoleLog(string.format("%d eggs bought!", bc), string.format("[🥚]:[✅] %d eggs bought!", bc), "DEBUG")
        WriteFileLog(string.format("%d eggs bought!", bc), "DEBUG")
        GUI.Notify("Info", string.format("%d eggs bought!", bc), "INFO", "info")
        _G.InternalConfig.EggsToBuyLeft -= bc
        farmed.total_eggs_bought += bc
        GUI.LabelUpdate(EggsBoughtLabel, string.format("%d : Eggs bought", farmed.total_eggs_bought), "egg", Color3.fromRGB(203, 92, 255), false)
        if _G.InternalConfig.EggsToBuyLeft == 0 then
          GUI.ToggleButtonSetValue(EggAutoBuyToggleButton, false)
          GUI.TextFieldSetValue(EggBuyCountTextField, "")
          GUI.DropdownSetValue(EggToBuyDropdown, {""})
          WriteConsoleLog("[Egg AutoBuy]: Bought all as expected", nil, "DEBUG")
          WriteFileLog("[Egg AutoBuy]: Bought all as expected", "DEBUG")
          return
        end
        if _G.InternalConfig.EggsToBuyLeft > 0 and bc == 99 then
          Cooldown.AutoFarm.TryBuyEggAfter = 0
          return
        end
        local after = ClientData.get("money")
        local spent = money - after
        StateDB.starter_value = StateDB.starter_value - spent
        Cooldown.AutoFarm.TryBuyEggAfter = 300
      end,
      function()
        return Cooldown.AutoFarm.TryBuyEggAfter == 0
      end,
      function()
        Cooldown.AutoFarm.TryBuyEggAfter = 5
      end)
    end
  end

