        GUI.Notify("Warning", "Set <Gift To Buy> at first.", "WARNING", "triangle-alert")
        GUI.ToggleButtonSetValue(GiftAutoBuyToggleButton, false)
        return
      end
      if GiftBuyCountTextField.CurrentValue == "" then
        GUI.Notify("Warning", "Set <Buy count> at first.", "WARNING", "triangle-alert")
