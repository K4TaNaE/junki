  local function __baby_callbak() 
    farmed.baby_ailments += 1 
    UpdateGui("baby_needs", farmed.baby_ailments)
    GUI.LabelUpdate(RuntimeStatsBabyNeedsCompletedLabel, string.format("Baby needs completed : %d", farmed.baby_ailments), "baby", Color3.fromRGB(203, 92, 255), false)
  end
  local function Enstat(age, friendship, money, ailment, baby_has_ailment)  
    local deadline = os.clock() + 5
    if money then 
      while money == ClientData.get("money") and os.clock() < deadline do
        task.wait(.1)
      end
      CalculateMoney()
    else
      task.wait(.5)
    end
    if deadline < os.clock() then
      print("Went beyond the deadline")
      return
    end
    if baby_has_ailment and ClientData.get("team") == "Babies" and not HasAilmentBaby(ailment) then
      __baby_callbak()
    end
    if actual_pet.is_egg then
      task.wait(2)
      if not GetOwnedEggs()[actual_pet.unique] then
        farmed.eggs_hatched += 1 
        farmed.ailments += 1
        UpdateGui("eggs", farmed.eggs_hatched)
        UpdateGui("pet_needs", farmed.ailments)
        GUI.LabelUpdate(RuntimeStatsEggsHatchedLabel, string.format("Eggs hatched : %d", farmed.eggs_hatched), "egg", Color3.fromRGB(203, 92, 255), false)
        GUI.LabelUpdate(RuntimeStatsPetNeedsCompletedLabel, string.format("Pet needs completed : %d", farmed.ailments), "cat", Color3.fromRGB(203, 92, 255), false)
        if not _G.InternalConfig.PetFarmDLib.PotionFarm or table.unpack(PetAutoFarmFarmTypeDropdown.CurrentOption) == "manual" then 
          actual_pet.unique = false 
          ClearPetFarmCache()
        else
          PetUpdate()
          task.wait(.3)
        end
      else
        farmed.ailments +=1
        UpdateGui("pet_needs", farmed.ailments)
        GUI.LabelUpdate(RuntimeStatsPetNeedsCompletedLabel, string.format("Pet needs completed : %d", farmed.ailments), "cat", Color3.fromRGB(203, 92, 255), false)
      end
      return
    end
    if age < 6 and ClientData.get("pet_char_wrappers")[1].pet_progression.age == 6 then
      farmed.pets_fullgrown += 1
      UpdateGui("fullgrown", farmed.pets_fullgrown)
      GUI.LabelUpdate(RuntimeStatsPetsFullgrownLabel, string.format("Pets full-grown : %d", farmed.pets_fullgrown), "move-up-right", Color3.fromRGB(203, 92, 255), false)
      StateDB.total_fullgrowned[actual_pet.unique] = true
      if not _G.InternalConfig.PetFarmDLib.PotionFarm or table.unpack(PetAutoFarmFarmTypeDropdown.CurrentOption) == "manual" then
        if not _G.InternalConfig.PetFarmDLib.flag_if_no_one_to_farm then
          actual_pet.unique = false
        end
      end
    end
    if friendship < ClientData.get("inventory").pets[actual_pet.unique].properties.friendship_level then
      farmed.friendship_levels += 1
      farmed.potions += 1
      UpdateGui("friendship", farmed.friendship_levels)
      UpdateGui("potions", farmed.potions)
      GUI.LabelUpdate(RuntimeStatsFriendshipLevelsFarmedLabel, string.format("Friendship levels farmed : %d", farmed.friendship_levels), "handshake", Color3.fromRGB(203, 92, 255), false)
      GUI.LabelUpdate(RuntimeStatsPotionsLabel, string.format("Potions farmed : %d", farmed.potions), "milk", Color3.fromRGB(203, 92, 255), false)
    end
    farmed.ailments += 1
    UpdateGui("pet_needs", farmed.ailments)
    GUI.LabelUpdate(RuntimeStatsPetNeedsCompletedLabel, string.format("Pet needs completed : %d", farmed.ailments), "cat", Color3.fromRGB(203, 92, 255), false)
  end
  local function __pet_callback(age, friendship, ailment) 
    if not _G.InternalConfig.FarmPriority then
      farmed.ailments += 1
      UpdateGui("pet_needs", farmed.ailments) 
      GUI.LabelUpdate(RuntimeStatsPetNeedsCompletedLabel, string.format("Pet needs completed : %d", farmed.ailments), "cat", Color3.fromRGB(203, 92, 255), false)
    else
      Enstat(age, friendship, nil, ailment)
    end
  end
