  GUI.Tabs.AutoTrade.Sections.AutoTrade.Callbacks.ToggleAutoTrade = function(v) 
    WriteConsoleLog("Auto trade triggered", nil, "DEBUG")
    WriteFileLog("Auto trade triggered", "DEBUG")
    if v then
      Cooldown.AutoTrade.NextTradeAfter = 0
      Registry.RegisterTask("auto_trade_handler", function()
        Cooldown.AutoTrade.NextTradeAfter = nil
        WriteConsoleLog(string.format("[Registry]: {auto_trade_handler} runned", v), nil, "ERROR")
        WriteFileLog(string.format("[Registry]: {auto_trade_handler} runned", v), "ERROR")
        local user = PlayerTradeWithTextField.CurrentValue 
        local need_repeat = false
        local pets_to_send = {}
        local confirmed = false
        if game.Players:FindFirstChild(user) then
          if not game.Players[user].Character or not game.Players[user].Character.Humanoid then
            Cooldown.AutoTrade.NextTradeAfter = 5
            GUI.Notify("Info", "Player located. Waiting for player loads the game", "INFO", "loader")
            return 
          end
          local owned_pets = GetOwnedPets()
          for k,v in owned_pets do
            if v.remote ~= "practice_dog" then
              if _G.InternalConfig.TradeDLib.TradeFarmed and StateDB.total_fullgrowned[k] then
                pets_to_send[k] = true
                continue
              end
              if TradePriorityDropdown.CurrentOption == "eggs" and not (v.name:lower()):match("egg") then
                continue
              elseif TradePriorityDropdown.CurrentOption == "pets" and (v.name:lower()):match("egg") then
                continue
              end
              if _G.InternalConfig.TradeDLib.BlacklistedRarities and _G.InternalConfig.TradeDLib.BlacklistedRarities[v.rarity] then
                continue
              end
              if _G.InternalConfig.TradeDLib.BlacklistedAges and _G.InternalConfig.TradeDLib.BlacklistedAges[v.age] then
                continue
              end
              if _G.InternalConfig.TradeDLib.BlacklistedProperties then
                if v.neon and _G.InternalConfig.TradeDLib.BlacklistedProperties["neon"] then continue end
                if v.mega_neon and _G.InternalConfig.TradeDLib.BlacklistedProperties["meganeon"] then continue end
                if v.flyable and _G.InternalConfig.TradeDLib.BlacklistedProperties["flyable"] then continue end
                if v.rideable and _G.InternalConfig.TradeDLib.BlacklistedProperties["rideable"] then continue end
              end
              if _G.InternalConfig.TradeDLib.ExcludeFriendly and v.friendship > 0 then
                continue
              end
              if _G.InternalConfig.TradeDLib.BlacklistedSpecificPets and _G.InternalConfig.TradeDLib.BlacklistedSpecificPets[v.remote] then
                continue
              end
              pets_to_send[k] = true
            end
          end
          if count(pets_to_send) == 0 then
            Cooldown.AutoTrade.NextTradeAfter = 60
            WriteConsoleLog(string.format("Internal pet list to trade is empty. Cooldown: [60]s", v), "[🔄]:[‼️] Internal pet list to trade is empty. Cooldown: [60]s.", "DEBUG")
            WriteFileLog(string.format("Internal pet list to trade is empty. Cooldown: [60]s", v), "DEBUG")
            GUI.Notify("Warning", "Internal pet list to trade is empty. Cooldown: [60]s", "WARNING", "triangle-alert")
            return
          elseif count(pets_to_send) > 18 then
            need_repeat = true
            for k in pairs(pets_to_send) do
              pets_to_send[k] = nil
              if count(pets_to_send) <= 18 then
                break
              end
            end
          end
          local r = send_trade_request(user)
          if r == "No response" then
            WriteConsoleLog(string.format("[AutoTrade]: No response from: {%s}", user), string.format("[🔄]:[‼️] No response from: %s", user), "DEBUG")
            WriteFileLog(string.format("[AutoTrade]: No response from: {%s}", user), "DEBUG")
            GUI.Notify("Warning", string.format("No response from: %s", user), "WARNING", "triangle-alert")
            Cooldown.AutoTrade.NextTradeAfter = tonumber(TradeFallbackDelayTextField.CurrentValue) or 40
            return
          elseif r == "declined" then
            WriteConsoleLog(string.format("[AutoTrade]: Trade declined by {%s}", user), string.format("[🔄]:[‼️] Trade declined by", user), "DEBUG")
            WriteFileLog(string.format("[AutoTrade]: Trade declined by {%s}", user), "DEBUG")
            GUI.Notify("Warning", string.format("Trade declined by %s", user), "WARNING", "triangle-alert")
            Cooldown.AutoTrade.NextTradeAfter = tonumber(TradeFallbackDelayTextField.CurrentValue) or 40
            return 
          end
          task.wait(1)
          local deadline = os.clock() + 180
          local ui = UIManager.apps.TradeApp
          if ui.visible then 
            ui.negotiation_decline_button.mouse_button1_click = function() GUI.Notify("Warning", "Decline button is locked for script better working", "WARNING", "triangle-alert") end 
            ui.confirmation_decline_button.mouse_button1_click = function() GUI.Notify("Warning", "Cancel button is locked for script better working", "WARNING", "triangle-alert") end 
            ui.negotiation_accept_button.mouse_button1_click  = function() GUI.Notify("Warning", "Accept button is locked for script better working", "WARNING", "triangle-alert") end 
            ui.confirmation_accept_button.mouse_button1_click  = function() GUI.Notify("Warning", "Confirm button is locked for script better working", "WARNING", "triangle-alert") end 
            ui.my_negotiation_offer_pane.add_item_callback = function() GUI.Notify("Warning", "Add item button is locked for script better working", "WARNING", "triangle-alert") end 
            pcall(function()
              for k,_ in pairs(pets_to_send) do 
                SafeFire("TradeAPI/AddItemToOffer", k)
                task.wait(.25)
              end
            end)
            while task.wait(1) and ui.visible and os.clock() < deadline do
              if ui:_get_current_trade_stage() == "negotiation" then
                if ui:_get_partner_offer().negotiated then
                  SafeFire("TradeAPI/AcceptNegotiation")
                else
                  continue
                end
              elseif ui:_get_current_trade_stage() == "confirmation" then
                if ui:_get_partner_offer().confirmed then
                  SafeFire("TradeAPI/ConfirmTrade")
                  confirmed = true
                else
                  continue
                end
              end
            end
            if os.clock() > deadline then
              SafeFire("TradeAPI/DeclineTrade")
              local _cdl = tonumber(TradeFallbackDelayTextField.CurrentValue) or 40
              WriteConsoleLog(string.format("[AutoTrade]: Trade is taking longer than expected. Repeating after [%d]s", _cdl), string.format("[🔄]:[‼️] Trade is taking longer than expected. Repeating after [%d]s.", _cdl), "DEBUG")
              WriteFileLog(string.format("[AutoTrade]: Trade is taking longer than expected. Repeating after [%d]s", _cdl), "DEBUG")
              GUI.Notify("Warning", string.format("Trade is taking longer than expected. Repeating after [%d]s", _cdl), "WARNING", "triangle-alert")
              Cooldown.AutoTrade.NextTradeAfter = _cdl
              return
            end
          else
            Cooldown.AutoTrade.NextTradeAfter = tonumber(TradeFallbackDelayTextField.CurrentValue) or 40
            return
          end
          if not confirmed then
            local _cdl = tonumber(TradeFallbackDelayTextField.CurrentValue) or 40
            WriteConsoleLog("[Auto Trade]: Trade unsuccessed", "[🔄]:[❌] Trade unsuccessed.", "ERROR")
            WriteFileLog("[Auto Trade]: Trade unsuccessed", "ERROR")
            GUI.Notify("Error", "Trade unsuccessed", "ERROR", "circle-x")
            farmed.unsuccessful_trades += 1 
            GUI.LabelUpdate(TradeUnsuccessfulTradesLabel, string.format("%d : Unsuccessful Trades", farmed.unsuccessful_trades), "book-check", Color3.fromRGB(203, 92, 255), false)
            if _G.InternalConfig.TradeDLib.DiscordWebhookLog then 
              if _G.InternalConfig.TradeDLib.DiscordWebhookUrl then 
                webhook(
                  "Trade-Log",
                  "```diff\n- Trade with " 
                  .. user 
                  .. " unsuccessed. Timeout: [" 
                  .. _cdl 
                  .. "]s.\n```"
                )
              else
                GUI.Notify("Warning", "Unable to send discord webhook log due to <discord webhook url> in <Webhooks> section is not set", "WARNING", "triangle-alert") 
              end
            end
            if _G.InternalConfig.TradeDLib.TelegramWebhookLog then
              if _G.InternalConfig.TelegramBotApi and _G.InternalConfig.TelegramChatId then
                telegram_webhook(string.format([[
                <code>Trade-Log</code>
                  <b>Trade with %s unsuccessed. Timeout: [%d]s.</b>
                ]], user, _cdl))
              else
                GUI.Notify("Warning", "Unable to send telegram webhook log due to <telegram bot api key> or <telegram chat id> in <Webhooks> section is not set", "WARNING", "triangle-alert") 
              end
            end
            Cooldown.AutoTrade.NextTradeAfter = _cdl
            return
          end
          WriteConsoleLog(string.format("[Auto Trade]: Trade with {%s} successed", user), string.format("[🔄]:[✅] Trade with %s successed.", user), "DEBUG")
          WriteFileLog(string.format("[Auto Trade]: Trade with {%s} successed", user), "DEBUG")
          GUI.Notify("Success", string.format("Trade with %s successed", user), "SUCCESS", "circle-check")
            farmed.successful_trades += 1 
            GUI.LabelUpdate(TradeSuccessfulTradesLabel, string.format("%d : Successful Trades", farmed.successful_trades), "book-check", Color3.fromRGB(203, 92, 255), false)
            if _G.InternalConfig.TradeDLib.DiscordWebhookLog then 
              if _G.InternalConfig.TradeDLib.DiscordWebhookUrl then 
                webhook("Trade-Log", "```diff\n+ Trade with " .. user .. " succeeded.\n```")		
                Cooldown.AutoTrade.NextTradeAfter = tonumber(TradeDelayTextField.CurrentValue) or 3600
              else
                GUI.Notify("Warning", "Unable to send discord webhook log due to <discord webhook url> in <Webhooks> section is not set", "WARNING", "triangle-alert") 
              end
            end
            if _G.InternalConfig.TradeDLib.TelegramWebhookLog then
              if _G.InternalConfig.TelegramBotApi and _G.InternalConfig.TelegramChatId then
                telegram_webhook(string.format([[
                <code>Trade-Log</code>
                  <b>Trade with %s unsuccessed. Timeout: [%d]s.</b>
                ]], user, _cdl))
              else
                GUI.Notify("Warning", "Unable to send telegram webhook log due to <telegram bot api key> or <telegram chat id> in <Webhooks> section is not set", "WARNING", "triangle-alert") 
              end
            end
          if need_repeat then
            GUI.Notify("Info", "Detected more than 18 pets to trade. Trade will be repeated soon after 5s.", "INFO", "settings")
            Cooldown.AutoTrade.NextTradeAfter = 5	
          end
        else
          Cooldown.AutoTrade.NextTradeAfter = 60
        end
      end,
      function()
        return Cooldown.AutoTrade.NextTradeAfter == 0
      end,
      function()
        Cooldown.AutoTrade.NextTradeAfter = TradeDelayTextField.CurrentValue
      end)
      WriteConsoleLog("Auto trade enabled", nil, "DEBUG")
      WriteFileLog("Auto trade enabled", "DEBUG")
    else
      Registry.UnregisterTask("auto_trade_handler")
      Cooldown.AutoTrade.NextTradeAfter = nil
      WriteConsoleLog("Auto trade disabled", nil, "DEBUG")
      WriteFileLog("Auto trade disabled","DEBUG")
    end
  end

