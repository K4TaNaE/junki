local function init_auto_recycle() 
  if not _G.pet_recycler_precessing then 
    local pets_to_exchange = {}
    local owned_pets = get_owned_pets()
    local value = 0
    for k,v in owned_pets do
      if v.remote == "practice_dog" then continue end
      if _G.InternalConfig.PetExchangeRarityBlacklist and _G.InternalConfig.PetExchangeRarityBlacklist[v.rarity] then continue end
      if _G.InternalConfig.PetExchangeAgeBlacklist and _G.InternalConfig.PetExchangeAgeBlacklist[v.age] then continue end
      if (v.name:lower()):match("egg") then continue end
      local ok, val = pcall(Calculator.get_pet_value, 
        { 
          kind = v.remote, 
          properties = {
            age = v.age,
            neon = v.neon,
            mega_neon = v.mega_neon,
            rideable = v.rideable,
            flyable = v.flyable
          },
        }
      ) 
      if ok then 
        value += val 
        pets_to_exchange[k] = true
      end
    end
	local val = (value + (ClientData.get("pet_recycler_manager").saved_points or 0)) 
    if val >= 4500 then 
      emulate_location("Nursery")
      if not ClientData.get("pet_recycler_manager").timestamp then
        safeInvoke("HousingAPI/ActivateInteriorFurniture",
          "f-9",
    	  "UseBlock",
    	  {
    	    action = "use",
    	    uniques = pets_to_exchange
    	  },
    	  LocalPlayer.Character
    	)
  	  task.wait(1)
	  _G.pet_recycler_precessing = true
	  local tmps = ClientData.get("pet_recycler_manager").timestamp
	  local ok, tms = pcall(LiveOpsTime.get_time_until, tmps)
	  if not ok or not tms then 
		tms = 300
	  end
	  Cooldown.init_auto_recycle = tms + 5
	  return
      end
	else
  	  print(string.format("[♻️]:[❌] Not enough points to use pet recycler (%d of 4500). Next try in [1200]s.", val))
	  Cooldown.init_auto_recycle = 300 
	  return
	end
  end
  local timestamp = ClientData.get("pet_recycler_manager").timestamp 
  if timestamp and LiveOpsTime.get_time_until(timestamp) > 1 then	
	local expr = ClientData.get("pet_recycler_manager").expected_rewards 
	if expr and expr.reward_kinds then
	  local rewards = {}
	  for _,v in ClientData.get("pet_recycler_manager").expected_rewards.reward_kinds or {} do
	  	table.insert(rewards, v)
	  end
	  emulate_location("Nursery")    
	  safeInvoke("HousingAPI/ActivateInteriorFurniture",
	    "f-9",
	    "UseBlock",
	    {
	      action = "claim"
	    },
	    LocalPlayer.Character
	  )
	  task.wait(1)
	  if not ClientData.get("pet_recycler_manager").expected_rewards or count((ClientData.get("pet_recycler_manager").expected_rewards or {})) == 0 then
        print("[♻️]:[🎁] Successfully received rewards from pet recycler:", table.unpack(rewards) .. ". Next recycle after [5]s.")
	    _G.pet_recycler_precessing = false
	    Cooldown.init_auto_recycle = 5
	    return		
	  else
        Cooldown.init_auto_recycle = 5
	    return
	  end	
    end
  end
end
